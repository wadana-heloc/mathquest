# MathQuest backend — environment template.
# Copy to `.env` (git-ignored) and fill in with real values.
#
# ⚠️  NEVER put real secrets in this file. Real secrets live in `.env`,
#     which is git-ignored. This file is checked into the repo.

# ---- Supabase ----------------------------------------------------------------
# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=https://<project-ref>.supabase.co

# Anon key — safe to expose on clients, but we still load it here because the
# backend uses it for password sign-in flows (the admin key cannot sign in).
SUPABASE_ANON_KEY=

# Service role key — SECRET. Grants full DB + admin API access (bypasses RLS).
# Never ship to the browser. Never log. Never commit.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret used by Supabase Auth to sign access tokens. Used to verify
# tokens on incoming requests. Find it at: Project Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# ---- App ---------------------------------------------------------------------
# Comma-separated list of origins allowed to call this API (CORS).
# Include the frontend's origin here.
CORS_ORIGINS=http://localhost:3000

# 'dev' | 'prod'. Controls logging verbosity and Swagger UI availability
# (Swagger at /docs is only exposed when APP_ENV=dev).
APP_ENV=dev
